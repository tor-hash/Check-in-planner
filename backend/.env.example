DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ENVIRONMENT=development
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DATABASE_URL=sqlite:///db.sqlite3
GOOGLE_OAUTH2_KEY=replace-with-client-id
GOOGLE_OAUTH2_SECRET=replace-with-client-secret
GOOGLE_WORKSPACE_DOMAIN=blackcapitaltechnology.com
# Comma-separated allowlist of exact emails that may sign in. Leave empty
# to let any user from GOOGLE_WORKSPACE_DOMAIN in. When set, only these
# addresses can create / sign in to user accounts.
GOOGLE_WORKSPACE_ALLOWED_EMAILS=

# Phase 2: server-side Google Calendar (freeBusy + event creation).
# Set to your manager users' default time zone.
GOOGLE_CALENDAR_TIMEZONE=Europe/Copenhagen

# Phase 4: keep the legacy Google Sheet journal sync alive temporarily.
# Set to False once the import_journal_sheet command has backfilled prod.
USE_GOOGLE_SHEET_JOURNAL=False
